# Cloudflare Workers Environment Variables
# Copy this file to .env.local for local development with wrangler

# Groq API Key for AI chat functionality
# Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq Model (optional, defaults to mixtral-8x7b-32768)
# Other options: llama2-70b-4096, gemma-7b-it
GROQ_MODEL=mixtral-8x7b-32768

# Cloudflare KV Namespace Binding (set in wrangler.toml)
# Uncomment to enable KV-based static file caching
# KV_STORE=your_kv_namespace_id

# Cloudflare R2 Bucket Binding (set in wrangler.toml)
# Uncomment to enable R2-based asset storage
# ASSETS=your_r2_bucket_name
